#!/bin/sh
# Xray Management Panel API - CGI for Debian (nginx + fcgiwrap)
XRAY_CONF="/usr/local/xray/config.json"
XRAY_BIN="/usr/local/xray/xray"
XRAY_DIR="/usr/local/xray"
PASSWORD_FILE="/usr/local/xray/.panel_pwd"
TOKEN_FILE="/tmp/.xray_panel_token"
DEFAULT_PWD="admin"

# Read POST body
if [ "$REQUEST_METHOD" = "POST" ] && [ -n "$CONTENT_LENGTH" ]; then
    BODY=$(dd bs=1 count="$CONTENT_LENGTH" 2>/dev/null)
else
    BODY=""
fi

# JSON response
json_resp() {
    printf "Status: 200 OK\r\nContent-Type: application/json; charset=utf-8\r\nAccess-Control-Allow-Origin: *\r\n\r\n%s" "$1"
}

# CORS preflight
if [ "$REQUEST_METHOD" = "OPTIONS" ]; then
    printf "Status: 200 OK\r\nAccess-Control-Allow-Origin: *\r\nAccess-Control-Allow-Methods: POST, OPTIONS\r\nAccess-Control-Allow-Headers: Content-Type\r\n\r\n"
    exit 0
fi

# Parse request fields using jq
ACTION=$(echo "$BODY" | jq -r '.action // empty' 2>/dev/null)
TOKEN=$(echo "$BODY" | jq -r '.token // empty' 2>/dev/null)
PASSWORD=$(echo "$BODY" | jq -r '.password // empty' 2>/dev/null)
NEW_PASSWORD=$(echo "$BODY" | jq -r '.new_password // empty' 2>/dev/null)

# Password helpers
get_pwd() { [ -f "$PASSWORD_FILE" ] && cat "$PASSWORD_FILE" || echo "$DEFAULT_PWD"; }
verify_token() {
    [ -n "$TOKEN" ] && [ -f "$TOKEN_FILE" ] && [ "$TOKEN" = "$(cat $TOKEN_FILE 2>/dev/null)" ]
}
gen_token() {
    local t=$(head -c 32 /dev/urandom | md5sum | cut -d' ' -f1)
    echo "$t" > "$TOKEN_FILE"
    chmod 600 "$TOKEN_FILE"
    echo "$t"
}

# === LOGIN ===
if [ "$ACTION" = "login" ]; then
    if [ "$PASSWORD" = "$(get_pwd)" ]; then
        # Reuse existing token if valid, avoid invalidating active sessions
        if [ -f "$TOKEN_FILE" ]; then
            T=$(cat "$TOKEN_FILE")
        else
            T=$(gen_token)
        fi
        json_resp "{\"token\":\"$T\"}"
    else
        json_resp '{"error":"密码错误"}'
    fi
    exit 0
fi

# Auth check for all other actions
if ! verify_token; then
    json_resp '{"error":"unauthorized"}'
    exit 0
fi

# === ACTIONS ===
case "$ACTION" in
status)
    PID=$(pgrep -f "$XRAY_BIN" | head -1)
    if [ -n "$PID" ]; then
        RUNNING="true"
        RSS=$(awk '/VmRSS/{print int($2/1024)}' /proc/$PID/status 2>/dev/null)
        [ -z "$RSS" ] && RSS=0
    else
        RUNNING="false"
        PID="--"
        RSS=0
    fi
    MEM_TOTAL=$(free | awk '/Mem:/{print int($2/1024)}')
    MEM_USED=$(free | awk '/Mem:/{print int($3/1024)}')
    MEM_AVAIL=$(free | awk '/Mem:/{print int($7/1024)}')
    CONN=$(ss -tnp 2>/dev/null | grep xray | wc -l)
    LOAD=$(cut -d' ' -f1-3 /proc/loadavg)
    CPUS=$(grep -c processor /proc/cpuinfo)
    DISK=$(df -h / | awk 'NR==2{print $3"/"$2" ("$5")"}')
    SYS_UP=$(uptime | sed 's/.*up //;s/,.*load.*//')
    UPTIME_FULL=$(uptime | tr -d '\n')
    # Use jq to build JSON safely (handles special characters)
    jq -n \
        --argjson running "$RUNNING" \
        --arg pid "$PID" \
        --arg system_uptime "$SYS_UP" \
        --arg mem_used "${MEM_USED}MB" \
        --arg mem_total "${MEM_TOTAL}MB" \
        --arg mem_free "${MEM_AVAIL}MB" \
        --arg connections "$CONN" \
        --arg system_info "负载: $LOAD | CPU: ${CPUS}核 | 内存: ${MEM_USED}MB/${MEM_TOTAL}MB (可用${MEM_AVAIL}MB) | 磁盘: $DISK | Xray RSS: ${RSS}MB | $UPTIME_FULL" \
        '{running:$running, pid:$pid, system_uptime:$system_uptime, mem_used:$mem_used, mem_total:$mem_total, mem_free:$mem_free, connections:$connections, system_info:$system_info}' \
        > /tmp/.xray_status_resp
    json_resp "$(cat /tmp/.xray_status_resp)"
    rm -f /tmp/.xray_status_resp
    ;;
restart)
    systemctl restart xray >/dev/null 2>&1
    sleep 2
    if pgrep -f "$XRAY_BIN" >/dev/null; then
        json_resp '{"message":"Xray 已重启"}'
    else
        json_resp '{"error":"重启失败"}'
    fi
    ;;
stop)
    systemctl stop xray >/dev/null 2>&1
    json_resp '{"message":"Xray 已停止"}'
    ;;
start)
    systemctl start xray >/dev/null 2>&1
    sleep 2
    if pgrep -f "$XRAY_BIN" >/dev/null; then
        json_resp '{"message":"Xray 已启动"}'
    else
        json_resp '{"error":"启动失败"}'
    fi
    ;;
test)
    # Run all 4 tests in parallel for faster response
    curl -s -o /dev/null -w '%{http_code}|%{time_total}' --connect-timeout 8 https://www.google.com > /tmp/.xray_t1 2>&1 &
    curl -s -o /dev/null -w '%{http_code}|%{time_total}' --connect-timeout 8 http://gitlab.hisense.com/users/sign_in > /tmp/.xray_t2 2>&1 &
    curl -s -o /dev/null -w '%{http_code}|%{time_total}' --connect-timeout 8 http://172.16.43.111 > /tmp/.xray_t3 2>&1 &
    curl -s -o /dev/null -w '%{http_code}|%{time_total}' --connect-timeout 8 https://www.baidu.com > /tmp/.xray_t4 2>&1 &
    wait
    T1=$(cat /tmp/.xray_t1); T2=$(cat /tmp/.xray_t2); T3=$(cat /tmp/.xray_t3); T4=$(cat /tmp/.xray_t4)
    rm -f /tmp/.xray_t1 /tmp/.xray_t2 /tmp/.xray_t3 /tmp/.xray_t4
    parse_test() {
        local code=$(echo "$1" | cut -d'|' -f1)
        local time=$(echo "$1" | cut -d'|' -f2)
        local ok="false"
        [ "$code" -ge 200 ] 2>/dev/null && [ "$code" -lt 400 ] 2>/dev/null && ok="true"
        echo "{\"ok\":$ok,\"code\":\"$code\",\"time\":\"${time}s\"}"
    }
    R1=$(parse_test "$T1")
    R2=$(parse_test "$T2")
    R3=$(parse_test "$T3")
    R4=$(parse_test "$T4")
    json_resp "{\"results\":{\"test-google\":$R1,\"test-office-domain\":$R2,\"test-office-ip\":$R3,\"test-baidu\":$R4}}"
    ;;
config_get)
    CONFIG_B64=$(base64 -w0 "$XRAY_CONF" 2>/dev/null)
    json_resp "{\"config_b64\":\"$CONFIG_B64\"}"
    ;;
config_save)
    CONFIG_B64=$(echo "$BODY" | jq -r '.config_b64 // empty' 2>/dev/null)
    if [ -n "$CONFIG_B64" ]; then
        echo "$CONFIG_B64" | base64 -d > /tmp/.xray_panel_cfg 2>/dev/null
        if jq empty /tmp/.xray_panel_cfg 2>/dev/null; then
            cp "$XRAY_CONF" "${XRAY_CONF}.bak"
            cp /tmp/.xray_panel_cfg "$XRAY_CONF"
            json_resp '{"message":"配置已保存（需重启生效）"}'
        else
            json_resp '{"error":"JSON 格式无效"}'
        fi
        rm -f /tmp/.xray_panel_cfg
    else
        json_resp '{"error":"无效请求"}'
    fi
    ;;
config_validate)
    R=$($XRAY_BIN run -test -c "$XRAY_CONF" 2>&1)
    if echo "$R" | grep -q 'Configuration OK'; then
        json_resp '{"message":"Configuration OK"}'
    else
        ERR=$(echo "$R" | grep -i 'fail' | tail -1)
        # Use jq to safely escape the error message
        RESP=$(jq -n --arg err "$ERR" '{error: ("语法错误: " + $err)}')
        json_resp "$RESP"
    fi
    ;;
logs)
    # Support lines parameter from frontend
    ERROR_LINES=$(echo "$BODY" | jq -r '.error_lines // empty' 2>/dev/null)
    ACCESS_LINES=$(echo "$BODY" | jq -r '.access_lines // empty' 2>/dev/null)
    [ -z "$ERROR_LINES" ] && ERROR_LINES=50
    [ -z "$ACCESS_LINES" ] && ACCESS_LINES=30
    {
        printf "=== Error Log (last %s lines) ===\n" "$ERROR_LINES"
        tail -"$ERROR_LINES" /var/log/xray/error.log 2>/dev/null
        printf "\n=== Access Log (last %s lines) ===\n" "$ACCESS_LINES"
        tail -"$ACCESS_LINES" /var/log/xray/access.log 2>/dev/null
    } > /tmp/.xray_logs_tmp
    LOGS_B64=$(base64 -w0 /tmp/.xray_logs_tmp)
    rm -f /tmp/.xray_logs_tmp
    json_resp "{\"logs_b64\":\"$LOGS_B64\"}"
    ;;
change_password)
    if [ -n "$NEW_PASSWORD" ]; then
        PWD_LEN=$(echo -n "$NEW_PASSWORD" | wc -c)
        if [ "$PWD_LEN" -ge 4 ]; then
            printf '%s' "$NEW_PASSWORD" > "$PASSWORD_FILE"
            chmod 600 "$PASSWORD_FILE"
            # Invalidate current token, force re-login
            rm -f "$TOKEN_FILE"
            json_resp '{"message":"密码已修改，请重新登录"}'
        else
            json_resp '{"error":"密码至少4位"}'
        fi
    else
        json_resp '{"error":"密码至少4位"}'
    fi
    ;;
geodata_status)
    GEOIP_SIZE=$(wc -c < "$XRAY_DIR/geoip.dat" 2>/dev/null || echo 0)
    GEOSITE_SIZE=$(wc -c < "$XRAY_DIR/geosite.dat" 2>/dev/null || echo 0)
    GEOIP_MB=$(awk "BEGIN{printf \"%.1f\", ${GEOIP_SIZE}/1048576}")
    GEOSITE_MB=$(awk "BEGIN{printf \"%.1f\", ${GEOSITE_SIZE}/1048576}")
    GEOIP_DATE=$(date -r "$XRAY_DIR/geoip.dat" '+%Y-%m-%d %H:%M' 2>/dev/null || echo "unknown")
    GEOSITE_DATE=$(date -r "$XRAY_DIR/geosite.dat" '+%Y-%m-%d %H:%M' 2>/dev/null || echo "unknown")
    SCHEDULE=$(crontab -l 2>/dev/null | grep 'update-geodata' | awk '{print $1, $2, $3, $4, $5}')
    json_resp "{\"geoip\":\"${GEOIP_MB}MB (${GEOIP_DATE})\",\"geosite\":\"${GEOSITE_MB}MB (${GEOSITE_DATE})\",\"schedule\":\"$SCHEDULE\"}"
    ;;
geodata_update)
    # Run in background to avoid CGI timeout
    nohup /bin/sh -c '/usr/local/xray/update-geodata.sh > /tmp/.geodata_update_result 2>&1; echo $? > /tmp/.geodata_update_exit' >/dev/null 2>&1 &
    json_resp '{"message":"规则库更新已启动（后台执行中，约1-2分钟完成）"}'
    ;;
geodata_update_status)
    # Check if background update is still running
    if pgrep -f "update-geodata.sh" >/dev/null 2>&1; then
        json_resp '{"status":"running","message":"更新中..."}'
    elif [ -f /tmp/.geodata_update_exit ]; then
        EXIT_CODE=$(cat /tmp/.geodata_update_exit)
        RESULT=$(cat /tmp/.geodata_update_result 2>/dev/null | tail -5)
        rm -f /tmp/.geodata_update_exit /tmp/.geodata_update_result
        if [ "$EXIT_CODE" = "0" ]; then
            json_resp '{"status":"done","message":"规则库更新完成，已重启 Xray"}'
        else
            RESP=$(jq -n --arg msg "$RESULT" '{status:"error", message: ("更新失败: " + $msg)}')
            json_resp "$RESP"
        fi
    else
        json_resp '{"status":"idle","message":"无正在进行的更新"}'
    fi
    ;;
geodata_schedule)
    SCHEDULE=$(echo "$BODY" | jq -r '.schedule // empty' 2>/dev/null)
    crontab -l 2>/dev/null | grep -v 'update-geodata' > /tmp/.cron_tmp
    if [ -n "$SCHEDULE" ]; then
        echo "$SCHEDULE /usr/local/xray/update-geodata.sh >> /var/log/geodata-update.log 2>&1" >> /tmp/.cron_tmp
    fi
    crontab /tmp/.cron_tmp
    rm -f /tmp/.cron_tmp
    if [ -n "$SCHEDULE" ]; then
        json_resp '{"message":"定时计划已保存"}'
    else
        json_resp '{"message":"定时更新已禁用"}'
    fi
    ;;
office_nets_get)
    NETS=$(cat "$XRAY_DIR/office-networks.txt" 2>/dev/null)
    NETS_JSON=$(echo "$NETS" | jq -R -s 'split("\n") | map(select(length > 0))' 2>/dev/null)
    json_resp "{\"networks\":$NETS_JSON}"
    ;;
office_nets_save)
    NETS=$(echo "$BODY" | jq -r '.networks // empty' 2>/dev/null)
    if [ -n "$NETS" ]; then
        echo "$NETS" | jq -r '.[]' > "$XRAY_DIR/office-networks.txt" 2>/dev/null
        /usr/local/xray/update-office-nets.sh >/dev/null 2>&1
        json_resp '{"message":"内网 IP 段已更新（nftables 已热更新，xray config 已同步，需重启 Xray 完全生效）"}'
    else
        json_resp '{"error":"无效数据"}'
    fi
    ;;
*)
    json_resp '{"error":"未知操作"}'
    ;;
esac
